# Known-good baseline (local Ollama + memory backend + serve mode)
HARNESS_MODEL_MODE=ollama
HARNESS_OLLAMA_ENDPOINT=http://127.0.0.1:11434
HARNESS_OLLAMA_MODEL=qwen3:0.6b
HARNESS_MODEL_TIMEOUT=120s

HARNESS_BACKEND_MODE=memory
HARNESS_XS_COMMAND=xs

HARNESS_SESSION_ID=demo
HARNESS_BRANCH_ID=main

HARNESS_SERVE_BIND=127.0.0.1
HARNESS_SERVE_PORT=8080

# Optional generic HTTP adapter mode
# HARNESS_MODEL_MODE=http
# HARNESS_MODEL_ENDPOINT=http://127.0.0.1:8081/v1/responses
# HARNESS_MODEL_AUTH_HEADER=Authorization
# HARNESS_MODEL_AUTH_KEY=
# HARNESS_MODEL_BEARER_TOKEN=

# --- v0.3.0: Self-healing, memory, dreaming, auditing ---

# Dream Daemon (background "sleep-time dreaming")
# DREAM_ENABLED=true
# DREAM_INACTIVITY_HOURS=24
# DREAM_MIN_SESSIONS=5
# DREAM_TOPIC_DIR=/tmp/pancakes-topics

# Self-auditing & cost-aware termination
# MAX_TOKENS_PER_CONSULT=16000
# AUTO_TERMINATE_ON_AUDIT_COMPLETE=false

# Three-layer memory (RAM index)
# MEMORY_INDEX_SIZE=1024

# Context compaction
# COMPACTION_TURNS=10
# COMPACTION_RATIO=0.8
